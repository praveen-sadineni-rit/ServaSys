# Supabase project settings (Project Settings > API in the Supabase dashboard).
# Copy this file to .env.local and fill in real values — .env.local is gitignored.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# In the Supabase dashboard, enable the Google provider under Authentication > Providers,
# and set these Authorized redirect URIs in your Google Cloud OAuth client:
#   http://localhost:3000/Timesheet/auth/callback
#   https://www.servasys.com/Timesheet/auth/callback
